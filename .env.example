# ─── Base de datos ────────────────────────────────────────────────────────────
# Nombre de la base de datos PostgreSQL
DB_NAME=fleetops_asignaciones

# Usuario de la base de datos
DB_USERNAME=fleetops_user

# Contraseña de la base de datos (reemplazar con valor seguro)
DB_PASSWORD=your_db_password_here

# ─── Servidor ─────────────────────────────────────────────────────────────────
# Puerto en que expone el microservicio
SERVER_PORT=8080

# ─── Seguridad JWT ────────────────────────────────────────────────────────────
# El API Gateway firma los JWT con su llave privada RSA; este microservicio solo
# valida la firma con la llave pública correspondiente (montada por volumen).
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY_PATH=/app/secrets/jwt_public.pem
# ─── Kafka ────────────────────────────────────────────────────────────────────
# Puerto externo de Kafka (para acceso desde host local)
KAFKA_EXTERNAL_PORT=9092

# Consumer group del microservicio
KAFKA_CONSUMER_GROUP_ID=asignaciones-group

# Prefijo del ID transaccional del producer (garantiza atomicidad DB + Kafka)
# Debe ser único por instancia del microservicio
KAFKA_PRODUCER_TRANSACTION_ID_PREFIX=asignaciones-tx

# ─── Topics Kafka ─────────────────────────────────────────────────────────────
# Asignaciones publica → Vehículos consume (coreografía)
KAFKA_TOPIC_VEHICULOS_SOLICITAR=fleetops.vehiculos.solicitar
KAFKA_TOPIC_VEHICULOS_LIBERAR=fleetops.vehiculos.liberar

# Vehículos publica → Asignaciones consume (coreografía)
KAFKA_TOPIC_VEHICULOS_CONFIRMADO=fleetops.asignaciones.vehiculo.confirmado
KAFKA_TOPIC_VEHICULOS_FALLIDO=fleetops.asignaciones.vehiculo.fallido

# Asignaciones publica → otros microservicios consumen
KAFKA_TOPIC_ASIGNACION_COMPLETADA=fleetops.asignaciones.completada
KAFKA_TOPIC_ASIGNACION_FALLIDA=fleetops.asignaciones.fallida

# ─── AWS (Incidentes publica en SNS → fan-out a esta cola SQS) ────────────────
# Región de las colas SQS. En AWS real, las credenciales se resuelven con el rol
# IAM de la instancia/tarea (no se configuran aquí). Para LocalStack en local,
# exportar además SPRING_CLOUD_AWS_CREDENTIALS_ACCESS_KEY/SECRET_KEY=test y
# SPRING_CLOUD_AWS_SQS_ENDPOINT=http://localhost:4566
AWS_REGION=us-east-1

# Nombre (local/LocalStack) o ARN (entorno real) de la cola SQS suscrita al
# tópico SNS de Incidentes
SQS_QUEUE_INCIDENTES_FALLA=arn:aws:sqs:us-east-1:255615880629:queue_assignations
